 installopt:
diff --git a/otherlibs/systhreads/Makefile b/otherlibs/systhreads/Makefile
index b22b645f45700806baf13beb85b3fcb1434006b0..343e685ae39eb8d3243a9612feeedae6303e49f2 100644
--- a/otherlibs/systhreads/Makefile
+++ b/otherlibs/systhreads/Makefile
@@ -111,30 +111,28 @@ clean: partialclean
 	rm -f dllthreads*.so dllthreads*.dll *.a *.lib *.o *.obj
 	rm -rf $(DEPDIR)
 
-INSTALL_THREADSLIBDIR=$(INSTALL_LIBDIR)/$(LIBNAME)
-
 install:
 ifeq "$(SUPPORTS_SHARED_LIBRARIES)" "true"
 	$(INSTALL_PROG) $(DLLTHREADS) "$(INSTALL_STUBLIBDIR)"
 endif
 	$(INSTALL_DATA) libthreads.$(A) "$(INSTALL_LIBDIR)"
-	mkdir -p "$(INSTALL_THREADSLIBDIR)"
+	$(MKDIR) "$(INSTALL_LIBDIR_SYSTHREADS)"
 	$(INSTALL_DATA) \
 	  $(CMIFILES) threads.cma \
-	  "$(INSTALL_THREADSLIBDIR)"
+	  "$(INSTALL_LIBDIR_SYSTHREADS)"
 ifeq "$(INSTALL_SOURCE_ARTIFACTS)" "true"
 	$(INSTALL_DATA) \
 	  $(CMIFILES:.cmi=.cmti) \
-	  "$(INSTALL_THREADSLIBDIR)"
-	$(INSTALL_DATA) $(MLIFILES) "$(INSTALL_THREADSLIBDIR)"
+	  "$(INSTALL_LIBDIR_SYSTHREADS)"
+	$(INSTALL_DATA) $(MLIFILES) "$(INSTALL_LIBDIR_SYSTHREADS)"
 endif
-	$(INSTALL_DATA) threads.h "$(INSTALL_LIBDIR)/caml"
+	$(INSTALL_DATA) threads.h "$(INSTALL_LIBDIR_CAML)"
 
 installopt:
 	$(INSTALL_DATA) libthreadsnat.$(A) "$(INSTALL_LIBDIR)"
 	$(INSTALL_DATA) \
 	  $(THREADS_NCOBJS) threads.cmxa threads.$(A) \
-	  "$(INSTALL_THREADSLIBDIR)"
+	  "$(INSTALL_LIBDIR_SYSTHREADS)"
 
 %.cmi: %.mli
 	$(CAMLC) -c $(COMPFLAGS) $<
diff --git a/runtime/Makefile b/runtime/Makefile
index e5cfb24282aeb84be5c44844c80f0190501888ad..150336cbe31101ba96c274db459f98a0d3e052c4 100644
