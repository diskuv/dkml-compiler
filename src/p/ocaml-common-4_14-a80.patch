 .PHONY: install
 
 ifeq "$(SUFFIXING)" "true"
@@ -207,8 +206,8 @@ $(foreach shared_runtime, $(BYTECODE_SHARED_LIBRARIES), \
   $(eval $(call INSTALL_RUNTIME_LIB,$(shared_runtime),BYTECODE)))
 
