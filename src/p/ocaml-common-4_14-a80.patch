-	$(MKDIR) "$(INSTALL_COMPLIBDIR)"
+	$(MKDIR) "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(MKDIR) "$(INSTALL_DOCDIR)"
 	$(MAKE) -C runtime install
 	$(INSTALL_PROG) ocaml$(EXE) "$(INSTALL_BINDIR)"
@@ -415,21 +411,21 @@ endif
 	$(INSTALL_PROG) yacc/ocamlyacc$(EXE) "$(INSTALL_BINDIR)"
 	$(INSTALL_DATA) \
 	  $(call COMPILER_ARTEFACT_DIRS, *.cmi) \
-	  "$(INSTALL_COMPLIBDIR)"
+	  "$(INSTALL_LIBDIR_COMPILERLIBS)"
 ifeq "$(INSTALL_SOURCE_ARTIFACTS)" "true"
 	$(INSTALL_DATA) \
 	  $(call COMPILER_ARTEFACT_DIRS, *.cmt *.cmti *.mli) \
-	  "$(INSTALL_COMPLIBDIR)"
+	  "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(INSTALL_DATA) \
 	   toplevel/byte/*.cmt \
-	   "$(INSTALL_COMPLIBDIR)"
+	   "$(INSTALL_LIBDIR_COMPILERLIBS)"
 endif
 	$(INSTALL_DATA) \
 	  compilerlibs/*.cma \
-	  "$(INSTALL_COMPLIBDIR)"
+	  "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(INSTALL_DATA) \
 	   $(BYTESTART) $(TOPLEVELSTART) \
-	   "$(INSTALL_COMPLIBDIR)"
+	   "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(INSTALL_PROG) $(expunge) "$(INSTALL_LIBDIR)"
 	$(INSTALL_DATA) \
 	   toplevel/topdirs.cmi \
@@ -465,9 +461,9 @@ ifeq "$(INSTALL_BYTECODE_PROGRAMS)" "true"
 	$(INSTALL_PROG) \
 	  boot/flexlink.byte$(EXE) "$(INSTALL_BINDIR)/flexlink.byte$(EXE)"
 endif # ifeq "$(INSTALL_BYTECODE_PROGRAMS)" "true"
-	$(MKDIR) "$(INSTALL_FLEXDLLDIR)"
+	$(MKDIR) "$(INSTALL_LIBDIR_FLEXDLL)"
 	$(INSTALL_DATA) $(addprefix stdlib/flexdll/, $(FLEXDLL_OBJECTS)) \
-    "$(INSTALL_FLEXDLLDIR)"
+    "$(INSTALL_LIBDIR_FLEXDLL)"
 endif # ifeq "$(BOOTSTRAPPING_FLEXDLL)" "true"
 	$(INSTALL_DATA) Makefile.config "$(INSTALL_LIBDIR)"
 	$(INSTALL_DATA) $(DOC_FILES) "$(INSTALL_DOCDIR)"
@@ -495,39 +491,39 @@ endif
 	$(MAKE) -C stdlib installopt
 	$(INSTALL_DATA) \
 	    middle_end/*.cmi \
-	    "$(INSTALL_COMPLIBDIR)"
+	    "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(INSTALL_DATA) \
 	    middle_end/closure/*.cmi \
-	    "$(INSTALL_COMPLIBDIR)"
+	    "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(INSTALL_DATA) \
 	    middle_end/flambda/*.cmi \
-	    "$(INSTALL_COMPLIBDIR)"
+	    "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(INSTALL_DATA) \
 	    middle_end/flambda/base_types/*.cmi \
-	    "$(INSTALL_COMPLIBDIR)"
+	    "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(INSTALL_DATA) \
 	    asmcomp/*.cmi \
-	    "$(INSTALL_COMPLIBDIR)"
+	    "$(INSTALL_LIBDIR_COMPILERLIBS)"
 ifeq "$(INSTALL_SOURCE_ARTIFACTS)" "true"
 	$(INSTALL_DATA) \
 	    $(addprefix middle_end/, *.cmt *.cmti *.mli) \
-	    "$(INSTALL_COMPLIBDIR)"
+	    "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(INSTALL_DATA) \
 	    $(addprefix middle_end/closure/, *.cmt *.cmti *.mli) \
-	    "$(INSTALL_COMPLIBDIR)"
+	    "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(INSTALL_DATA) \
 	    $(addprefix middle_end/flambda/, *.cmt *.cmti *.mli) \
-	    "$(INSTALL_COMPLIBDIR)"
+	    "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(INSTALL_DATA) \
 	    $(addprefix middle_end/flambda/base_types/, *.cmt *.cmti *.mli) \
-	    "$(INSTALL_COMPLIBDIR)"
+	    "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(INSTALL_DATA) \
 	    $(addprefix asmcomp/, *.cmt *.cmti *.mli) \
-	    "$(INSTALL_COMPLIBDIR)"
+	    "$(INSTALL_LIBDIR_COMPILERLIBS)"
 endif
 	$(INSTALL_DATA) \
 	    $(OPTSTART) \
-	    "$(INSTALL_COMPLIBDIR)"
+	    "$(INSTALL_LIBDIR_COMPILERLIBS)"
 ifneq "$(WITH_OCAMLDOC)" ""
 	$(MAKE) -C ocamldoc installopt
 endif
@@ -567,15 +563,15 @@ endif
 	$(INSTALL_DATA) \
 	  $(call COMPILER_ARTEFACT_DIRS, *.cmx, $(NATIVE_ARTEFACT_DIRS)) \
 	  toplevel/native/tophooks.cmi \
-    "$(INSTALL_COMPLIBDIR)"
+    "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(INSTALL_DATA) \
 	   compilerlibs/*.cmxa compilerlibs/*.$(A) \
-	   "$(INSTALL_COMPLIBDIR)"
+	   "$(INSTALL_LIBDIR_COMPILERLIBS)"
 	$(INSTALL_DATA) \
 	   $(BYTESTART:.cmo=.$(O)) \
 	   $(OPTSTART:.cmo=.$(O)) \
 	   $(TOPLEVELSTART:.cmo=.$(O)) \
-	   "$(INSTALL_COMPLIBDIR)"
+	   "$(INSTALL_LIBDIR_COMPILERLIBS)"
 ifeq "$(INSTALL_OCAMLNAT)" "true"
 	  $(INSTALL_PROG) ocamlnat$(EXE) "$(INSTALL_BINDIR)"
 endif
@@ -587,7 +583,7 @@ ifeq "$(INSTALL_SOURCE_ARTIFACTS)" "true"
 	$(INSTALL_DATA) \
 	  $(call COMPILER_ARTEFACT_DIRS, *.ml, $(NATIVE_ARTEFACT_DIRS)) \
 	  toplevel/byte/*.ml \
-	  "$(INSTALL_COMPLIBDIR)"
+	  "$(INSTALL_LIBDIR_COMPILERLIBS)"
 endif
 
 # Run all tests
diff --git a/Makefile.common b/Makefile.common
index efc27c7d132ab54446ec5e9237c96ab3821e7d4e..cb25634d3fde8b575bfe9e55ed81e9c2eca51eed 100644
--- a/Makefile.common
+++ b/Makefile.common
@@ -40,13 +40,28 @@ endif
 
 QUOTE_SINGLE = '$(subst ','\'',$(1))'
 DESTDIR ?=
-INSTALL_BINDIR := $(DESTDIR)$(BINDIR)
-INSTALL_LIBDIR := $(DESTDIR)$(LIBDIR)
-INSTALL_STUBLIBDIR := $(DESTDIR)$(STUBLIBDIR)
-INSTALL_MANDIR := $(DESTDIR)$(MANDIR)
-INSTALL_PROGRAMS_MAN_DIR := $(DESTDIR)$(PROGRAMS_MAN_DIR)
-INSTALL_LIBRARIES_MAN_DIR := $(DESTDIR)$(LIBRARIES_MAN_DIR)
-INSTALL_DOCDIR := $(DESTDIR)$(DOCDIR)
+
+# Augment directories from Makefile.config / Makefile.build_config with
+# $(DESTDIR). i.e. each of these 5 directories may be overridden by the user,
+# and the compiler distribution makes no assumptions about where they are
+# relative to each other.
+INSTALL_BINDIR = $(DESTDIR)$(BINDIR)
+INSTALL_DOCDIR = $(DESTDIR)$(DOCDIR)
+INSTALL_LIBDIR = $(DESTDIR)$(LIBDIR)
+INSTALL_MANDIR = $(DESTDIR)$(MANDIR)
+INSTALL_STUBLIBDIR = $(DESTDIR)$(STUBLIBDIR)
+
+# Library subdirectories. The compiler distribution does make assumptions about
+# these, and they cannot be freely overridden by the user.
+INSTALL_LIBDIR_CAML = $(INSTALL_LIBDIR)/caml
+INSTALL_LIBDIR_COMPILERLIBS = $(INSTALL_LIBDIR)/compiler-libs
+INSTALL_LIBDIR_DYNLINK = $(INSTALL_LIBDIR)/dynlink
+INSTALL_LIBDIR_FLEXDLL = $(INSTALL_LIBDIR)/flexdll
+INSTALL_LIBDIR_OCAMLDOC = $(INSTALL_LIBDIR)/ocamldoc
+INSTALL_LIBDIR_SYSTHREADS = $(INSTALL_LIBDIR)/threads
+
+INSTALL_MANDIR_PROGRAMS = $(INSTALL_MANDIR)/man1
+INSTALL_MANDIR_LIBRARIES = $(INSTALL_MANDIR)/man3
 
 FLEXDLL_SUBMODULE_PRESENT := $(wildcard $(ROOTDIR)/flexdll/Makefile)
 
diff --git a/api_docgen/ocamldoc/Makefile b/api_docgen/ocamldoc/Makefile
index b6dbbf9da9a937339dcfc9a42fceb2611bc84b84..239d938271e42f7a53fb12b363c4007fefd4e4b8 100644
--- a/api_docgen/ocamldoc/Makefile
+++ b/api_docgen/ocamldoc/Makefile
@@ -121,6 +121,6 @@ build/latex/compilerlibs_input.tex: | build/latex
 
 .PHONY: install
 install:
-	$(MKDIR) "$(INSTALL_LIBRARIES_MAN_DIR)"
+	$(MKDIR) "$(INSTALL_MANDIR_LIBRARIES)"
 	$(if $(wildcard build/man), \
-	  $(INSTALL_DATA) build/man/*.3o "$(INSTALL_LIBRARIES_MAN_DIR)")
+	  $(INSTALL_DATA) build/man/*.3o "$(INSTALL_MANDIR_LIBRARIES)")
diff --git a/api_docgen/odoc/Makefile b/api_docgen/odoc/Makefile
index e8e189f37f8f6f25d7b82518cca82196767f117c..0ee95951543eb00f6797088d7cad6cc21d6f5553 100644
--- a/api_docgen/odoc/Makefile
+++ b/api_docgen/odoc/Makefile
@@ -191,11 +191,11 @@ $(ALL_PAGED_DOC:%=build/%.3o.stamp):build/%.3o.stamp:build/%.odocl | build/
 # Man pages are the only installed documentation
 .PHONY: install
 install:
-	$(MKDIR) "$(INSTALL_LIBRARIES_MAN_DIR)"
+	$(MKDIR) "$(INSTALL_MANDIR_LIBRARIES)"
 	$(if $(wildcard build/man/libref), \
-	  $(INSTALL_DATA) build/man/libref/* "$(INSTALL_LIBRARIES_MAN_DIR)")
+	  $(INSTALL_DATA) build/man/libref/* "$(INSTALL_MANDIR_LIBRARIES)")
 	$(if $(wildcard build/man/compilerlibref), \
-	  $(INSTALL_DATA) build/man/libref/* "$(INSTALL_LIBRARIES_MAN_DIR)")
+	  $(INSTALL_DATA) build/man/libref/* "$(INSTALL_MANDIR_LIBRARIES)")
 
 # Dependencies for stdlib modules.
 # Use the same dependencies used for compiling .cmx files.
diff --git a/man/Makefile b/man/Makefile
index 05424bab473741ca23b5e6899de7699e93a2470d..75e93ad88b6c189cddb8d75f8a6d1b0424fb8bbf 100644
--- a/man/Makefile
+++ b/man/Makefile
@@ -22,5 +22,5 @@ MANPAGES = $(addsuffix .1,\
 
 .PHONY: install
 install:
-	$(MKDIR) $(call QUOTE_SINGLE,$(INSTALL_PROGRAMS_MAN_DIR))
-	$(INSTALL_DATA) $(MANPAGES) $(call QUOTE_SINGLE,$(INSTALL_PROGRAMS_MAN_DIR))
+	$(MKDIR) $(call QUOTE_SINGLE,$(INSTALL_MANDIR_PROGRAMS))
+	$(INSTALL_DATA) $(MANPAGES) $(call QUOTE_SINGLE,$(INSTALL_MANDIR_PROGRAMS))
diff --git a/ocamldoc/Makefile b/ocamldoc/Makefile
index a3db466271c9efe68036ea77bc220c795b206713..1aa0910bc347de255feb3f670ac6d10728ee52b6 100644
--- a/ocamldoc/Makefile
+++ b/ocamldoc/Makefile
@@ -240,15 +240,15 @@ DEPEND_PREREQS = $(LEXERS:.mll=.ml) \
 .PHONY: install
 install:
 	$(MKDIR) "$(INSTALL_BINDIR)"
-	$(MKDIR) "$(INSTALL_LIBDIR)/ocamldoc"
+	$(MKDIR) "$(INSTALL_LIBDIR_OCAMLDOC)"
 	$(INSTALL_PROG) ocamldoc$(EXE) "$(INSTALL_BINDIR)"
 	$(INSTALL_DATA) \
 	  ocamldoc.hva *.cmi $(OCAMLDOC_LIBCMA) \
-	  "$(INSTALL_LIBDIR)/ocamldoc"
+	  "$(INSTALL_LIBDIR_OCAMLDOC)"
 ifeq "$(INSTALL_SOURCE_ARTIFACTS)" "true"
 	$(INSTALL_DATA) \
 	  $(OCAMLDOC_LIBMLIS) $(OCAMLDOC_LIBCMTS) \
-	  "$(INSTALL_LIBDIR)/ocamldoc"
+	  "$(INSTALL_LIBDIR_OCAMLDOC)"
 endif
 
 # Note: at the moment, $(INSTALL_MANODIR) is created even if the doc has
@@ -261,11 +261,11 @@ installopt:
 .PHONY: installopt_really
 installopt_really:
 	$(MKDIR) "$(INSTALL_BINDIR)"
-	$(MKDIR) "$(INSTALL_LIBDIR)/ocamldoc"
+	$(MKDIR) "$(INSTALL_LIBDIR_OCAMLDOC)"
 	$(INSTALL_PROG) ocamldoc.opt$(EXE) "$(INSTALL_BINDIR)"
 	$(INSTALL_DATA) \
 	  *.cmx $(OCAMLDOC_LIBA) $(OCAMLDOC_LIBCMXA) \
-	  "$(INSTALL_LIBDIR)/ocamldoc"
+	  "$(INSTALL_LIBDIR_OCAMLDOC)"
 
 # TODO: also split into several rules
 
diff --git a/otherlibs/Makefile.otherlibs.common b/otherlibs/Makefile.otherlibs.common
index 81ea589abd31dd31331ac71adf6e29fb7dcf4738..dca77225b43c848d81ff8882a65db5a88066e225 100644
--- a/otherlibs/Makefile.otherlibs.common
+++ b/otherlibs/Makefile.otherlibs.common
@@ -119,7 +119,7 @@ ifeq "$(INSTALL_SOURCE_ARTIFACTS)" "true"
 	  "$(INSTALL_LIBDIR)/"
 endif
 ifneq "$(HEADERS)" ""
