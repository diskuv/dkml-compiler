From 664e05cf265f505436539cf88a49c862327c0f28 Mon Sep 17 00:00:00 2001
From: David Allsopp <david.allsopp@metastack.com>
Date: Sat, 19 Jul 2025 14:16:31 +0100
Subject: [PATCH] Add SUBDIR_NAME to principal Makefiles

SUBDIR_NAME goes along with ROOTDIR - where ROOTDIR is the relative path
from Makefile back to the root directory, SUBDIR_NAME is the implicit
path from the root directory to Makefile.

(cherry picked from commit 588ec7560f6e709a1aa3f00c6dec1f6b6f7ba5be)

diff --git a/Makefile b/Makefile
index a29cbdd70d4d7ec4abd5ed2c8e844c4bccffa654..b03e1a8fbeed65bbd816d7e4efbd21013dc57e0c 100644
--- a/Makefile
+++ b/Makefile
@@ -16,6 +16,8 @@
 # The main Makefile
 
 ROOTDIR = .
+SUBDIR_NAME =
+
 # NOTE: it is important that OCAMLLEX is defined *before* Makefile.common
 # gets included, so that its definition here takes precedence
 # over the one there.
diff --git a/api_docgen/Makefile b/api_docgen/Makefile
index 07254645812ae43d8e1578e280debbd67e23c043..4ad898ea6bfd6802a4f83888ecdbfe0c983c429d 100644
--- a/api_docgen/Makefile
+++ b/api_docgen/Makefile
@@ -14,6 +14,7 @@
 #**************************************************************************
 # Used by included Makefiles
 ROOTDIR = ..
+SUBDIR_NAME = api_docgen
 -include ../Makefile.build_config
 
 odoc-%:
diff --git a/api_docgen/ocamldoc/Makefile b/api_docgen/ocamldoc/Makefile
index 239d938271e42f7a53fb12b363c4007fefd4e4b8..d3ec00a81cbb053adffc845d5540b8b9fd980f28 100644
--- a/api_docgen/ocamldoc/Makefile
+++ b/api_docgen/ocamldoc/Makefile
@@ -14,6 +14,7 @@
 #**************************************************************************
 # Used by included Makefiles
 ROOTDIR = ../..
+SUBDIR_NAME = api_docgen/ocamldoc
 include ../Makefile.common
 include ../../ocamldoc/Makefile.best_ocamldoc
 vpath %.mli ../../stdlib $(DOC_COMPILERLIBS_DIRS)  $(DOC_STDLIB_DIRS)
diff --git a/api_docgen/odoc/Makefile b/api_docgen/odoc/Makefile
index 0ee95951543eb00f6797088d7cad6cc21d6f5553..b0f1e8a8c80294a4d59431749d5f6801eb2731cd 100644
--- a/api_docgen/odoc/Makefile
+++ b/api_docgen/odoc/Makefile
@@ -15,6 +15,7 @@
 
 # Used by included Makefiles
 ROOTDIR = ../..
+SUBDIR_NAME = api_docgen/odoc
 
 include ../Makefile.common
 
diff --git a/debugger/Makefile b/debugger/Makefile
index 7e1ff1a74af7cdf14b51cc3214d82b6c0fe63951..14c3e951040456ac3141a5cf02aebd7dddaf1c1d 100644
