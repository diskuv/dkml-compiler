diff --git a/otherlibs/Makefile.otherlibs.common b/otherlibs/Makefile.otherlibs.common
index dca77225b43c848d81ff8882a65db5a88066e225..e309b7bd0f2811545f712e8686feb8fd6dc2d6c6 100644
--- a/otherlibs/Makefile.otherlibs.common
+++ b/otherlibs/Makefile.otherlibs.common
@@ -16,6 +16,7 @@
 # Common Makefile for otherlibs
 
 ROOTDIR=../..
+SUBDIR_NAME?=otherlibs/$(LIBNAME)
 include $(ROOTDIR)/Makefile.common
 include $(ROOTDIR)/Makefile.best_binaries
 
