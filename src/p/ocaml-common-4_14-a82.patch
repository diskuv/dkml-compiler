diff --git a/man/Makefile b/man/Makefile
index 75e93ad88b6c189cddb8d75f8a6d1b0424fb8bbf..49963ff07de83ec0a42836ee238d7199b149b3f7 100644
--- a/man/Makefile
+++ b/man/Makefile
