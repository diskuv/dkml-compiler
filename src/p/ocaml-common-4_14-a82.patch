diff --git a/otherlibs/win32unix/Makefile b/otherlibs/win32unix/Makefile
index 35371fe7d0bcf2b8efed8d974287dd9e15ed43ae..be9df075a233f74b14d7fdecdcfca0818f458c52 100644
--- a/otherlibs/win32unix/Makefile
+++ b/otherlibs/win32unix/Makefile
@@ -13,6 +13,8 @@
 #*                                                                        *
 #**************************************************************************
 
+SUBDIR_NAME = otherlibs/win32unix
