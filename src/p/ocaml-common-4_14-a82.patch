+++ b/ocamldoc/Makefile
@@ -14,6 +14,7 @@
 #**************************************************************************
 
 ROOTDIR = ..
+SUBDIR_NAME = ocamldoc
 
 include $(ROOTDIR)/Makefile.common
 include $(ROOTDIR)/Makefile.best_binaries
diff --git a/otherlibs/Makefile b/otherlibs/Makefile
index 0da6669b731f3bb7c329a3b84a30bba59409c5d4..dbe9c62a0916fa39f8062648bf4265e0b975a0ec 100644
--- a/otherlibs/Makefile
+++ b/otherlibs/Makefile
@@ -14,6 +14,7 @@
