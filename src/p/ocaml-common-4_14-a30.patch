diff --git a/configure.ac b/configure.ac
index da2fc2c1fcb7c8255239148adc9a1e43e7571898..67f42105dc23727c1cb7ea6c21b0636a24f2eb0b 100644
--- a/configure.ac
+++ b/configure.ac
@@ -365,6 +365,18 @@ AC_ARG_WITH([target-sh],
     [target_launch_method="$withval"])],
   [target_launch_method=''])
 
+AC_ARG_WITH([stublibs],
+  [AS_HELP_STRING([--with-stublibs],
+    [additional directory for searching for bytecode stub libraries])],
+  [AS_IF([test x"$withval" = 'xno'],
+    [ocaml_additional_stublibs_dir=''],
+    [dnl A user wishing to add "yes" to ld.conf may do so manually - catch
+     dnl --with-stublibs as an error.
+    AS_IF([test x"$withval" = 'xyes'],
+     [AC_MSG_ERROR([--with-stublibs needs an argument])])
+    ocaml_additional_stublibs_dir="$withval"])],
+  [ocaml_additional_stublibs_dir=''])
+
 AC_ARG_ENABLE([reserved-header-bits],
   [AS_HELP_STRING([--enable-reserved-header-bits=BITS],
   [reserve BITS (between 0 and 31) bits in block headers for profiling info])],
@@ -2134,4 +2146,15 @@ AC_CONFIG_COMMANDS_PRE([
   prefix="$saved_prefix"
   exec_prefix="$saved_exec_prefix"])
 
+# Create ld.conf
+AC_CONFIG_COMMANDS([runtime/ld.conf],
+  [rm -f runtime/ld.conf
+  test x"$ocaml_additional_stublibs_dir" = 'x' || \
+    echo "$ocaml_additional_stublibs_dir" > runtime/ld.conf
+  echo "$ocaml_libdir/stublibs" >> runtime/ld.conf
+  echo "$ocaml_libdir" >> runtime/ld.conf],
+  [ocaml_additional_stublibs_dir=\
+'$(echo "$ocaml_additional_stublibs_dir" | sed -e "s/'/'\"'\"'/g")'
+  ocaml_libdir='$(echo "$ocaml_libdir" | sed -e "s/'/'\"'\"'/g")'])
+
 AC_OUTPUT
diff --git a/ocaml-variants.opam b/ocaml-variants.opam
index f24327c157071791a6a4025eeb0176c932632b1d..da0d7469bbd78a68016c142c26969b539c89a119 100644
--- a/ocaml-variants.opam
+++ b/ocaml-variants.opam
@@ -65,6 +65,7 @@ build: [
     "--host=i686-w64-mingw32"   {os-distribution = "cygwin" & system-mingw:installed & arch-x86_32:installed}
     "--prefix=%{prefix}%"
     "--docdir=%{doc}%/ocaml"
+    "--with-stublibs=%{stublibs}%"
     "--with-flexdll=%{flexdll:share}%" {os = "win32" & flexdll:installed}
     "-C"
     "--with-afl" {ocaml-option-afl:installed}
diff --git a/runtime/Makefile b/runtime/Makefile
index 9b500d7c8c60a86af71757dbfa4cfde291f5ed8b..493359dba6efcbddf5af0431b71f2a82699f1d35 100644
--- a/runtime/Makefile
+++ b/runtime/Makefile
@@ -54,7 +54,7 @@ endif
 # Targets to build and install
 
 PROGRAMS := ocamlrun$(EXE)
-BYTECODE_STATIC_LIBRARIES := ld.conf libcamlrun.$(A)
+BYTECODE_STATIC_LIBRARIES := libcamlrun.$(A)
 BYTECODE_SHARED_LIBRARIES :=
 NATIVE_STATIC_LIBRARIES := libasmrun.$(A)
 NATIVE_SHARED_LIBRARIES :=
@@ -160,7 +160,7 @@ INSTALL_INCDIR=$(INSTALL_LIBDIR)/caml
 .PHONY: install
 install:
 	$(INSTALL_PROG) $(PROGRAMS) "$(INSTALL_BINDIR)"
-	$(INSTALL_DATA) $(BYTECODE_STATIC_LIBRARIES) "$(INSTALL_LIBDIR)"
+	$(INSTALL_DATA) ld.conf $(BYTECODE_STATIC_LIBRARIES) "$(INSTALL_LIBDIR)"
 ifneq "$(BYTECODE_SHARED_LIBRARIES)" ""
 	$(INSTALL_PROG) $(BYTECODE_SHARED_LIBRARIES) "$(INSTALL_LIBDIR)"
 endif
@@ -176,7 +176,7 @@ endif
 
 .PHONY: clean
 clean:
-	rm -f *.o *.obj *.a *.lib *.so *.dll ld.conf
+	rm -f *.o *.obj *.a *.lib *.so *.dll
 	rm -f ocamlrun ocamlrund ocamlruni ocamlruns sak
 	rm -f ocamlrun.exe ocamlrund.exe ocamlruni.exe ocamlruns.exe sak.exe
 	rm -f primitives primitives.new prims.c $(BUILT_HEADERS)
@@ -185,14 +185,10 @@ clean:
 
 .PHONY: distclean
 distclean: clean
-	rm -f $(CONFIGURED_HEADERS)
+	rm -f $(CONFIGURED_HEADERS) ld.conf
 
 # Generated non-object files
 
-ld.conf: $(ROOTDIR)/Makefile.config
-	echo "$(STUBLIBDIR)" > $@
-	echo "$(LIBDIR)" >> $@
-
 # If primitives contain duplicated lines (e.g. because the code is defined
 # like
 # #ifdef X
