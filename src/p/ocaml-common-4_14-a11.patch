diff --git a/configure.ac b/configure.ac
index d7f0a80f59dad0c07b2c784c85300846965b1788..84434e7ef4937fe19b6cf6aee8d90c36db004ee7 100644
--- a/configure.ac
+++ b/configure.ac
@@ -118,7 +118,6 @@ AC_SUBST([ocamlc_cflags])
 AC_SUBST([ocamlc_cppflags])
 AC_SUBST([flexdir])
 AC_SUBST([bootstrapping_flexdll])
-AC_SUBST([long_shebang])
 AC_SUBST([shebangscripts])
 AC_SUBST([AR])
 AC_SUBST([mklib])
@@ -593,19 +592,11 @@ AC_SYS_INTERPRETER
 
 shebangscripts=false
 launch_method='exe'
-long_shebang=false
 AS_IF([test "x$interpval" = "xyes"],
   [AS_CASE([$host],
     [*-cygwin|*-*-mingw32*|*-pc-windows], [],
     [shebangscripts=true
-    launch_method='sh'
-    prev_exec_prefix="$exec_prefix"
-    AS_IF([test "x$exec_prefix" = "xNONE"],[exec_prefix="$prefix"])
-    eval "expanded_bindir=¥"$bindir¥""
-    exec_prefix="$prev_exec_prefix"
-    # Assume maximum shebang is 128 chars; less #!, /ocamlrun, an optional
-    # 1 char suffix and the ¥0 leaving 115 characters
-    AS_IF([test "${#expanded_bindir}" -gt 115],[long_shebang=true])]
+    launch_method='sh']
   )]
 )
 
diff --git a/stdlib/Makefile b/stdlib/Makefile
index eaf5f938315ea2ec561d46ddef3930206d468412..974d2d465741dec4b5bc6f8397ee2b27f97561ef 100644
--- a/stdlib/Makefile
+++ b/stdlib/Makefile
@@ -55,8 +55,7 @@ NOSTDLIB= camlinternalFormatBasics.cmo camlinternalAtomic.cmo stdlib.cmo
 OTHERS=$(filter-out $(NOSTDLIB),$(OBJS))
 
 .PHONY: all
-all: stdlib.cma std_exit.cmo bootheader $(HEADER_NAME) target_$(HEADER_NAME) ¥
-     camlheader_ur
+all: stdlib.cma std_exit.cmo $(HEADER_NAME) target_$(HEADER_NAME) camlheader_ur
 
 ifeq "$(RUNTIMED)" "true"
 all: target_camlheaderd
@@ -123,20 +122,11 @@ installopt-default::
 
 ifeq "$(UNIX_OR_WIN32)" "unix"
 HEADERPROGRAM = header
-HEADER_PATH = $(BINDIR)/
 else # Windows
 HEADERPROGRAM = headernt
-HEADER_PATH =
 endif
 
 ifeq "$(SHEBANGSCRIPTS)" "true"
-bootheader: $(ROOTDIR)/Makefile.config Makefile
-ifeq "$(LONG_SHEBANG)" "true"
-	echo '#!/bin/sh' > $@
-	echo 'exec "$(BINDIR)/ocamlrun" "$$0" "$$@"' >> $@
-else
-	echo '#!$(BINDIR)/ocamlrun' > $@
-endif
 
 camlheader_ur: Makefile
 	echo '#!' | tr -d '¥012' > $@
@@ -146,13 +136,6 @@ target_camlheader%: Makefile
 
 else # Hashbang scripts not supported
 
-bootheader: $(HEADERPROGRAM).c $(ROOTDIR)/Makefile.config Makefile
-
-# $@.exe is deleted to ensure no Cygwin .exe mangling takes place
-bootheader: tmpheader.exe
-	rm -f $@.exe
-	cp $< $@
-
 camlheader_ur: tmpheader.exe
 	rm -f $@.exe
 	cp $< $@
@@ -177,9 +160,6 @@ ifneq "$(UNIX_OR_WIN32)" "win32"
 	strip $@
 endif
 
-$(HEADERPROGRAM)%$(O): ¥
-  OC_CPPFLAGS += -DRUNTIME_NAME='"$(HEADER_PATH)ocamlrun$(subst .,,$*)"'
-
 stdlib.cma: $(OBJS)
 	$(CAMLC) -a -o $@ $^
 
@@ -192,7 +172,7 @@ distclean: clean
 
 .PHONY: clean
 clean::
-	rm -f bootheader $(HEADER_NAME) target_$(HEADER_NAME)* camlheader_ur
+	rm -f $(HEADER_NAME) target_$(HEADER_NAME)* camlheader_ur
 
 export AWK
 
diff --git a/stdlib/header.c b/stdlib/header.c
index edcc3b34a8bb9c3dd7be76e3a8b0a4d9f243e8a9..e2572a024aa4731779f23bbbccc1d06340e89234 100644
--- a/stdlib/header.c
+++ b/stdlib/header.c
@@ -30,8 +30,6 @@
 #include "caml/mlvalues.h"
 #include "caml/exec.h"
 
-char * default_runtime_path = RUNTIME_NAME;
-
 #ifndef MAXPATHLEN
 #define MAXPATHLEN 1024
 #endif
@@ -155,11 +153,10 @@ static char * read_runtime_path(int fd)
     } else if (path_size > 0)
       ofs += read_size(buffer + 4);
   }
-  if (path_size == 0) return default_runtime_path;
+  if (path_size == 0) return NULL;
   if (path_size >= MAXPATHLEN) return NULL;
   lseek(fd, -ofs, SEEK_END);
   if (read(fd, runtime_path, path_size) != path_size) return NULL;
-  runtime_path[path_size - 1] = 0;
   return runtime_path;
 }
 
diff --git a/stdlib/headernt.c b/stdlib/headernt.c
index 7f37149640b3381eea886a9a62fe07b503f8ead8..998bb3e4dbdc331a1590938e0395e2adb7a7b78b 100644
--- a/stdlib/headernt.c
+++ b/stdlib/headernt.c
@@ -31,8 +31,6 @@
 #endif
 #endif
 
-char * default_runtime_name = RUNTIME_NAME;
-
 static
 #if _MSC_VER >= 1200
 __forceinline
@@ -70,12 +68,11 @@ static __inline char * read_runtime_path(HANDLE h)
     } else if (path_size > 0)
       ofs += read_size(buffer + 4);
   }
-  if (path_size == 0) return default_runtime_name;
+  if (path_size == 0) return NULL;
   if (path_size >= MAX_PATH) return NULL;
   if (SetFilePointer(h, -ofs, NULL, FILE_END) == -1) return NULL;
   if (! ReadFile(h, runtime_path, path_size, &nread, NULL)) return NULL;
   if (nread != path_size) return NULL;
-  runtime_path[path_size - 1] = 0;
   return runtime_path;
 }
 
