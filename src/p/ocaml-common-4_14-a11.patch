From: David Allsopp <david.allsopp@metastack.com>
Date: Wed, 17 Aug 2022 09:08:03 +0100
Subject: [PATCH] Remove last vestiges of camlheader post-bootstrap

(cherry picked from commit c9fcee3da2c988b0060c24c63eb75d91feaa4451)
(cherry picked from commit 62921f3939c17f16078789d4abc0856cf82b1984)

diff --git a/.gitignore b/.gitignore
index 4090b155cab70f94f7bcc49578d11247bb5c2a36..a3737edc9b9944003bc367d94e6f444749596238 100644
--- a/.gitignore
+++ b/.gitignore
@@ -205,7 +205,6 @@ _build
 /runtime/domain_state32.inc
 /runtime/domain_state64.inc
 
-/stdlib/bootheader
 /stdlib/camlheader
 /stdlib/target_camlheader*
 /stdlib/camlheader_ur
diff --git a/Makefile b/Makefile
index 42a11a0ba91e92ba0f55e773b8f9d432e92a0c05..43fd95216c2a9bc32d98adc4ebb8d0ea92d295b7 100644
--- a/Makefile
+++ b/Makefile
@@ -71,7 +71,7 @@ TOPLEVELINIT=toplevel/toploop.cmo
 # capitalized module names.
 PERVASIVES=$(STDLIB_MODULES) outcometree topdirs toploop
 
-LIBFILES=stdlib.cma std_exit.cmo *.cmi
+LIBFILES=stdlib.cma std_exit.cmo *.cmi $(HEADER_NAME)
 
 COMPLIBDIR=$(LIBDIR)/compiler-libs
 
@@ -172,8 +172,8 @@ else
 	$(MAKE) -C runtime $(BOOT_FLEXLINK_CMD) all
 endif # ifeq "$(BOOTSTRAPPING_FLEXDLL)" "false"
 	cp runtime/ocamlrun$(EXE) boot/ocamlrun$(EXE)
-	cd boot; rm -f $(LIBFILES) $(HEADER_NAME)
-	cd stdlib; cp $(LIBFILES) ../boot; cp bootheader ../boot/$(HEADER_NAME)
+	cd boot; rm -f $(LIBFILES)
+	cd stdlib; cp $(LIBFILES) ../boot
 	cd boot; $(LN) ../runtime/libcamlrun.$(A) .
 
 # Recompile the core system using the bootstrap compiler
diff --git a/Makefile.config.in b/Makefile.config.in
index 86fee8b4f5e299db51d4ae9ecc5704940a58c3ea..51fb2ceb7dd39dee9ebad1d325582a347617bf64 100644
--- a/Makefile.config.in
+++ b/Makefile.config.in
@@ -262,7 +262,7 @@ FLEXLINK=$(FLEXLINK_CMD) $(FLEXLINK_FLAGS)
 
 SHEBANGSCRIPTS=@shebangscripts@
 HASHBANGSCRIPTS=$(SHEBANGSCRIPTS)
-LONG_SHEBANG=@long_shebang@
+LONG_SHEBANG=false
 
 ## Variables renamed in OCaml 4.13
 
diff --git a/bytecomp/bytelink.ml b/bytecomp/bytelink.ml
index 62c24a73759f2fa8d9560e9b6d31f775c2d233cd..77a63a80d5a13fbb77911e2646f665c697be5040 100644
--- a/bytecomp/bytelink.ml
+++ b/bytecomp/bytelink.ml
@@ -370,14 +370,7 @@ let read_runtime_launch_info file =
     else
       {bindir; launcher; buffer; executable_offset}
   with Not_found ->
-    if String.starts_with ‾prefix:"#!" buffer then
-      let runtime = String.sub buffer 2 (String.index buffer '¥n' - 2) in
-      {bindir = Filename.dirname runtime; launcher = Shebang_bin_sh "sh";
-       buffer; executable_offset = 0}
-    else if String.starts_with ‾prefix:"MZ" buffer then
-      {bindir = ""; launcher = Executable; buffer; executable_offset = 0}
-    else
-      raise (Error (Camlheader ("corrupt header", file)))
+    raise (Error (Camlheader ("corrupt header", file)))
 
 let find_bin_sh () =
   let output_file = Filename.temp_file "caml_bin_sh" "" in
