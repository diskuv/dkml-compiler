@@ -170,6 +170,7 @@ AC_SUBST([compute_deps])
 AC_SUBST([naked_pointers])
 AC_SUBST([naked_pointers_checker])
 AC_SUBST([ar_supports_response_files])
+AC_SUBST([TARGET_LIBDIR])
 AC_SUBST([QS])
 AC_SUBST([target_bindir])
 
@@ -2127,6 +2128,7 @@ AC_CONFIG_COMMANDS_PRE([
   eval "ocaml_bindir=\"$bindir\""
   eval "ocaml_libdir=\"$libdir\""
   AS_IF([test x"$TARGET_BINDIR" = 'x'],[TARGET_BINDIR="$ocaml_bindir"])
+  TARGET_LIBDIR="$libdir"
   AS_IF([test x"$target_launch_method" = 'x'],
     [target_launch_method="$launch_method"])
   prefix="$saved_prefix"
diff --git a/runtime/Makefile b/runtime/Makefile
index b62a5791a93a22b80f888b34dcdf989eada790c3..e51ed64157f147a5ad145cae38324833b5f0bbf8 100644
--- a/runtime/Makefile
+++ b/runtime/Makefile
@@ -263,7 +263,7 @@ C_LITERAL = $(shell ./sak$(EXE) encode-C-literal '$(1)')
 
 build_config.h: $(ROOTDIR)/Makefile.config sak$(EXE)
 	echo '/* This file is generated from $(ROOTDIR)/Makefile.config */' > $@
-	echo '#define OCAML_STDLIB_DIR $(call C_LITERAL,$(LIBDIR))' >> $@
+	echo '#define OCAML_STDLIB_DIR $(call C_LITERAL,$(TARGET_LIBDIR))' >> $@
 	echo '#define HOST "$(HOST)"' >> $@
 
