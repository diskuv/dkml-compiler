From 9aedfb84b90bc615d99eacf1e32ecc645c3a8825 Mon Sep 17 00:00:00 2001
From: David Allsopp <david.allsopp@metastack.com>
Date: Sat, 6 Sep 2025 16:38:46 +0100
Subject: [PATCH] Got an interpreter, and we're not afraid to use it

(cherry picked from commit 6b5d740dbcf2a947098f69b137093876c120734f)

diff --git a/Makefile.common b/Makefile.common
index 2d206b2e261bf3b5b4ed752525b41ca01b24c891..d28b9bced22e5ed3bd93468c3d02a297b709af46 100644
--- a/Makefile.common
+++ b/Makefile.common
@@ -334,7 +334,8 @@ INSTALL_DESPATCH_opam_BEGIN = \
 # Munge opam-bin, opam-lib, opam-libexec and opam-man into a .install file and
 # then munge clone-* and create-symlinks into the fixup script.
 INSTALL_DESPATCH_opam_END = \
-  tools/opam/generate-install.sh $(OPAM_PACKAGE_NAME) $(UNIX_OR_WIN32) '$(LN)'
+  $(OCAMLRUN) ./ocaml$(EXE) $(STDLIBFLAGS) \
+    tools/opam/generate.ml $(INSTALL_MODE) $(OPAM_PACKAGE_NAME) '$(LN)'
 
 # Generate $(OPAM_PACKAGE_NAME)-clone.sh (INSTALL_MODE=clone)
 
@@ -364,8 +365,7 @@ INSTALL_DESPATCH_clone_MKDIR =
 
 INSTALL_DESPATCH_clone_BEGIN = rm -f clone-* create-symlinks
 
-INSTALL_DESPATCH_clone_END = \
-  tools/opam/generate-clone.sh $(OPAM_PACKAGE_NAME) $(UNIX_OR_WIN32) '$(LN)'
+INSTALL_DESPATCH_clone_END = $(INSTALL_DESPATCH_opam_END)
 
 FLEXDLL_SUBMODULE_PRESENT := $(wildcard $(ROOTDIR)/flexdll/Makefile)
 
