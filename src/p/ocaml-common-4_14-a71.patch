From 5dc0c56b558d11edafa91277c68a414f4827b8c8 Mon Sep 17 00:00:00 2001
From: David Allsopp <david.allsopp@metastack.com>
Date: Thu, 17 Jul 2025 11:13:54 +0100
Subject: [PATCH] Don't explicitly install toplevel/byte/*.cmi

All of the .mli files in toplevel/byte are "common", so they're already
installed by the patterns in toplevel.

(cherry picked from commit 1878e0441085f6908d585b58ec0177788b4720e2)

diff --git a/Makefile b/Makefile
index 3157d01bfcc38d0ce4d237ac736f9c1731dbe943..d6a127bfd58d1e9f03c8579be4ea28718ed80dd4 100644
--- a/Makefile
+++ b/Makefile
@@ -408,9 +408,6 @@ endif
 	   driver/*.cmi \
 	   toplevel/*.cmi \
 	   "$(INSTALL_COMPLIBDIR)"
-	$(INSTALL_DATA) \
-	   toplevel/byte/*.cmi \
-	   "$(INSTALL_COMPLIBDIR)"
 ifeq "$(INSTALL_SOURCE_ARTIFACTS)" "true"
 	$(INSTALL_DATA) \
 	   utils/*.cmt utils/*.cmti utils/*.mli \
-- 
2.53.0.windows.2

