From 38472b0a9f2d68eff09e1f3483bffa5ef222b8fa Mon Sep 17 00:00:00 2001
From: David Allsopp <david.allsopp@metastack.com>
Date: Wed, 12 Feb 2025 13:57:24 +0000
Subject: [PATCH] Increase reproducibility of relative artefacts

(cherry picked from commit 3ccb0364a2a0d3a641c9fd15c47dd11967afd06c)

diff --git a/Makefile.build_config.in b/Makefile.build_config.in
index cbfb69a067f7d5be36913deb5537a97358ea4796..1173585a920df2706cdcab69b0533af0e6c6ca5c 100644
--- a/Makefile.build_config.in
+++ b/Makefile.build_config.in
@@ -33,6 +33,16 @@ AS_IS_CC = @as_is_cc@
 DEP_CC=@DEP_CC@ -MM
 COMPUTE_DEPS=@compute_deps@
 
+# The C compiler vendor
+OCAML_CC_VENDOR = @ocaml_cc_vendor@
+
+BUILD_PATH_LOGICAL = @srcdir_abs@
+BUILD_PATH_PHYSICAL = @srcdir_abs_real@
+BUILD_MAP_FLAGS = @build_map_flags@
+BUILD_MAP_CFLAGS = $(foreach flag, $(BUILD_MAP_FLAGS), \
+  $(call QUOTE_SINGLE,$(flag)$(BUILD_PATH_LOGICAL)=+build) \
+  $(if $(BUILD_PATH_PHYSICAL), \
+    $(call $(QUOTE_SINGLE),$(flag)$(BUILD_PATH_PHYSICAL)=+build)))
 # This is munged into utils/config.ml, not overridable by other parts of
 # the build system.
 OC_DLL_LDFLAGS=@oc_dll_ldflags@
diff --git a/Makefile.common b/Makefile.common
index 80743d1e69b0d46f43102a48f0b876186db5acbf..27bd27ec6b4555d90c641a7021ee60df62839fdd 100644
--- a/Makefile.common
+++ b/Makefile.common
@@ -27,6 +27,8 @@ MKDIR=mkdir -p
 EMPTY :=
 # $(SPACE) contains a single space
 SPACE := $(EMPTY) $(EMPTY)
+$(SPACE) :=
+HASH := \#
 
 ifeq "$(UNIX_OR_WIN32)" "win32"
 DIR_SEP := \$ # There must a space following the $
@@ -119,6 +121,21 @@ SUBST=-e 's!%%$1%%!$(call SED_ESCAPE,$($1))!'
 # in config.mlp.  Thus, backslashes and double quotes must be escaped.
 SUBST_STRING=-e 's!%%$1%%!$(call SED_ESCAPE,$(call OCAML_ESCAPE,$($1)))!'
 
+ifeq "$(TARGET_LIBDIR_IS_RELATIVE)" "true"
+  SRCDIR_ENCODED = $(subst =,%+,$(subst :,%.,$(subst %,%$(HASH),$(SRCDIR_ABS))))
+  SRCDIR_ABS_REAL := $(shell realpath $(SRCDIR_ABS) 2>/dev/null)
+  SRCDIR_REAL_ENCODED = \
+    $(subst =,%+,$(subst :,%.,$(subst %,%$(HASH),$(SRCDIR_ABS_REAL))))
+  BUILD_PATH_PREFIX_MAP ?=
+  export BUILD_PATH_PREFIX_MAP := \
+    $(BUILD_PATH_PREFIX_MAP)$\
+      :.=$(SRCDIR_ENCODED)$\
+      $(if $(SRCDIR_REAL_ENCODED),:.=$(SRCDIR_REAL_ENCODED))
+  PRIVATE_CFLAGS = $(BUILD_MAP_CFLAGS)
+else
+  PRIVATE_CFLAGS =
+endif # ifeq "$(TARGET_LIBDIR_IS_RELATIVE)" "true"
+
 # Allow Makefile.cross to override the Standard Library default for the compiler
 # itself.
 HOST_LIBDIR ?= $(TARGET_LIBDIR)
@@ -143,8 +160,8 @@ REQUIRED_HEADERS := $(RUNTIME_HEADERS) $(wildcard *.h)
 endif
 
 %.$(O): %.c $(REQUIRED_HEADERS)
-	$(CC) -c $(OC_CFLAGS) $(CFLAGS) $(OC_CPPFLAGS) $(CPPFLAGS) \
-	  $(OUTPUTOBJ)$@ $<
+	$(CC) -c $(OC_CFLAGS) $(CFLAGS) $(PRIVATE_CFLAGS) \
+	  $(OC_CPPFLAGS) $(CPPFLAGS) $(OUTPUTOBJ)$@ $<
 
 $(DEPDIR):
 	$(MKDIR) $@
