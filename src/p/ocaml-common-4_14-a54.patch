diff --git a/configure.ac b/configure.ac
index 8e6e93ea73be50492d7800c663d5796eb5472b54..3ea07afb6353aa0cfdc7787ec0d4c42303ec5de2 100644
--- a/configure.ac
+++ b/configure.ac
@@ -59,6 +59,9 @@ instrumented_runtime=false
 instrumented_runtime_libs=""
 bootstrapping_flexdll=false
 target_libdir_is_relative=false
+srcdir_abs=''
+srcdir_abs_real=''
+build_map_flags=''
 
 # Information about the package
 
@@ -178,6 +181,9 @@ AC_SUBST([TARGET_LIBDIR])
 AC_SUBST([QS])
 AC_SUBST([target_bindir])
 AC_SUBST([target_libdir_is_relative])
+AC_SUBST([srcdir_abs])
+AC_SUBST([srcdir_abs_real])
+AC_SUBST([build_map_flags])
 
 ## Generated files
 
@@ -612,8 +618,8 @@ AS_CASE([$lt_cv_ar_at_file],
 # See https://lists.gnu.org/archive/html/autoconf/2019-07/msg00002.html
 # for the detailed explanation.
 
-ocamlsrcdir=$(unset CDPATH; cd -- "$srcdir" && printf %sX "$PWD") || fail
-ocamlsrcdir=${ocamlsrcdir%X}
+srcdir_abs=$(unset CDPATH; cd -- "$srcdir" && printf %sX "$PWD") || fail
+srcdir_abs=${srcdir_abs%X}
 
 # Libraries to build depending on the host
 
@@ -622,11 +628,12 @@ AS_CASE([$cygwin_build_env,$host],
     [unix_or_win32="win32"
     OCAML_CHECK_LN_ON_WINDOWS
     default_separator='\'
-    ocamlsrcdir="$(LC_ALL=C.UTF-8 cygpath -w -- "$ocamlsrcdir")"
+    ocamlsrcdir="$(LC_ALL=C.UTF-8 cygpath -w -- "$srcdir_abs")"
     unixlib="win32unix"
     ],
   [unix_or_win32="unix"
   ln='ln -sf'
+  ocamlsrcdir="$srcdir_abs"
   default_separator='/'
   unixlib="unix"])
 
@@ -1817,6 +1824,20 @@ AS_CASE([$ocaml_cv_cc_vendor,$host],
   [sunc*,sparc-sun-*], [cc_has_debug_prefix_map=false],
   [OCAML_CC_HAS_DEBUG_PREFIX_MAP])
 
+## -ffile-prefix-map support by the C compiler - used in the build, not by
+## the compiler
+AS_IF([test x"$bindir_to_libdir" != 'x'],
+  [srcdir_abs_real="$(realpath "$srcdir_abs" 2>/dev/null)"
+  AS_IF([test x"$srcdir_abs_real" = "x$srcdir_abs"],
+    [srcdir_abs_real=''])
+  AX_CHECK_COMPILE_FLAG([-Wa,--debug-prefix-map=old=new],
+    [build_map_flags='-Wa,--debug-prefix-map='], [], [$warn_error_flag])
+  AX_CHECK_COMPILE_FLAG([-ffile-prefix-map=old=new],
+    [build_map_flags="$build_map_flags -ffile-prefix-map="],
+    [AS_IF([$cc_has_debug_prefix_map],
+      [build_map_flags="$build_map_flags -fdebug-prefix-map="])],
+    [$warn_error_flag])])
+
 ## Does stat support nanosecond precision
 
 AC_CHECK_MEMBER([struct stat.st_atim.tv_nsec],
diff --git a/debugger/Makefile b/debugger/Makefile
index 4518272c0b9ece212001a41401b603cc80aa8ee6..aaae909e1bd721c98537e4d338fe4bb21f42ce63 100644
--- a/debugger/Makefile
+++ b/debugger/Makefile
@@ -26,6 +26,14 @@ COMPFLAGS=$(INCLUDES) -absname -w +a-4-9-41-42-44-45-48-70 -warn-error +A \
           -safe-string -strict-sequence -strict-formats
 LINKFLAGS=-linkall -I $(UNIXDIR) -I $(DYNLINKDIR) -I $(ROOTDIR)/runtime \
           -set-runtime-default 'standard_library_default=$(TARGET_LIBDIR)'
+ifeq "$(SUPPORTS_SHARED_LIBRARIES)" "false"
+ifeq "$(TARGET_LIBDIR_IS_RELATIVE)" "true"
+  # ocamldebug is linked with -g which will result in a -custom executable when
+  # shared libraries are not available. Ensure that the primitives object is
+  # compiled with the correct flags
+  LINKFLAGS += $(addprefix -ccopt$(SPACE), $(BUILD_MAP_CFLAGS))
+endif
+endif
 CAMLDEP=$(BEST_OCAMLDEP)
 DEPFLAGS=-slash
 DEPINCLUDES=$(INCLUDES)
diff --git a/ocamldoc/Makefile b/ocamldoc/Makefile
index b5b6411fded3ee5f4e348e0df18306588d9f4ca2..229d875c62546ea2531ad03ba2f0d34a4161cef4 100644
--- a/ocamldoc/Makefile
+++ b/ocamldoc/Makefile
@@ -175,6 +175,15 @@ OCAMLDOC_NCLIBRARIES = $(OCAMLDOC_LIBRARIES:%=%.cmxa)
 
 $(eval $(call PROGRAM_SYNONYM,ocamldoc))
 
+ifeq "$(SUPPORTS_SHARED_LIBRARIES)" "false"
+ifeq "$(TARGET_LIBDIR_IS_RELATIVE)" "true"
+  # ocamldebug is linked with -g which will result in a -custom executable when
+  # shared libraries are not available. Ensure that the primitives object is
+  # compiled with the correct flags
+$(OCAMLDOC): LINKFLAGS += $(addprefix -ccopt$(SPACE), $(BUILD_MAP_CFLAGS))
+endif
+endif
+
 $(OCAMLDOC): $(EXECMOFILES)
 	$(OCAMLC) -o $@ -linkall $(LINKFLAGS) $(OCAMLDOC_BCLIBRARIES) $^
 
diff --git a/otherlibs/systhreads/Makefile b/otherlibs/systhreads/Makefile
index 5fff9c44ff972c77223a40436101c8af85891fa6..8f8cf540163ec8c76e376c53879b179f4489d513 100644
--- a/otherlibs/systhreads/Makefile
+++ b/otherlibs/systhreads/Makefile
@@ -95,8 +95,8 @@ st_stubs.%.$(O): st_stubs.c
 else
 st_stubs.%.$(O): st_stubs.c $(RUNTIME_HEADERS) $(wildcard *.h)
 endif
-	$(CC) -c $(OC_CFLAGS) $(CFLAGS) $(OC_CPPFLAGS) $(CPPFLAGS) \
-	  $(OUTPUTOBJ)$@ $<
+	$(CC) -c $(OC_CFLAGS) $(CFLAGS) $(PRIVATE_CFLAGS) \
+	  $(OC_CPPFLAGS) $(CPPFLAGS) $(OUTPUTOBJ)$@ $<
 
 partialclean:
 	rm -f *.cm*
diff --git a/runtime/Makefile b/runtime/Makefile
index f6b929278fe47357ab25bf0dc242424dc632e5af..69371b2ce73e76f600a6340c7fe44b2cf68f6343 100644
--- a/runtime/Makefile
+++ b/runtime/Makefile
@@ -371,8 +371,8 @@ $(1).$(O): $(2).c
 else
 $(1).$(O): $(2).c $(CONFIGURED_HEADERS) $(BUILT_HEADERS) $(RUNTIME_HEADERS)
 endif # ifneq "$(COMPUTE_DEPS)" "false"
-	$$(CC) -c $$(OC_CFLAGS) $$(CFLAGS) $$(OC_CPPFLAGS) $$(CPPFLAGS) \
-	  $$(OUTPUTOBJ)$$@ $$<
+	$$(CC) -c $$(OC_CFLAGS) $$(PRIVATE_CFLAGS) $$(CFLAGS) $$(OC_CPPFLAGS) \
+	  $$(CPPFLAGS) $$(OUTPUTOBJ)$$@ $$<
 endef
 
 object_types := % %.b %.bd %.bi %.bpic
