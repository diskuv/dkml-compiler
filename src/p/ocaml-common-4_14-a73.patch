From abe3acb4f8ab96e66c46d725c03044d61317faad Mon Sep 17 00:00:00 2001
From: David Allsopp <david.allsopp@metastack.com>
Date: Thu, 17 Jul 2025 11:16:10 +0100
Subject: [PATCH] Remove duplicate installation in installopt

The ocamldoc installation commands in installopt duplicate a series of
commands which already happen in install.

(cherry picked from commit 28492bc9edd90323b2d77009737d905cf0af52dc)

diff --git a/ocamldoc/Makefile b/ocamldoc/Makefile
index 74cc1e05f54a2dca7e065ef6ec2581008969becc..0a536545818e17f523a4c631f20079e8ea6e6e7b 100644
--- a/ocamldoc/Makefile
+++ b/ocamldoc/Makefile
@@ -267,15 +267,7 @@ installopt_really:
 	$(MKDIR) "$(INSTALL_LIBDIR)/ocamldoc"
 	$(INSTALL_PROG) $(OCAMLDOC_OPT) "$(INSTALL_BINDIR)"
 	$(INSTALL_DATA) \
-	  $(OCAMLDOC_LIBCMIS) \
-	  "$(INSTALL_LIBDIR)/ocamldoc"
-ifeq "$(INSTALL_SOURCE_ARTIFACTS)" "true"
-	$(INSTALL_DATA) \
-	  $(OCAMLDOC_LIBMLIS) $(OCAMLDOC_LIBCMTS) \
-	  "$(INSTALL_LIBDIR)/ocamldoc"
-endif
-	$(INSTALL_DATA) \
-	  ocamldoc.hva *.cmx $(OCAMLDOC_LIBA) $(OCAMLDOC_LIBCMXA) \
+	  *.cmx $(OCAMLDOC_LIBA) $(OCAMLDOC_LIBCMXA) \
 	  "$(INSTALL_LIBDIR)/ocamldoc"
 
 # TODO: also split into several rules
-- 
