diff --git a/stdlib/Makefile b/stdlib/Makefile
index 3d0e7582a8a6acce1a397a90a8fb2b1097f412c4..a764eea18f5c8aa7ff453f7844def637b2e22e03 100644
--- a/stdlib/Makefile
+++ b/stdlib/Makefile
@@ -89,7 +89,7 @@ ifeq "$(INSTALL_SOURCE_ARTIFACTS)" "true"
 	  *.cmt *.cmti *.mli *.ml \
 	  "$(INSTALL_LIBDIR)"
 endif
-	$(INSTALL_DATA) target_$(HEADER_NAME) "$(INSTALL_LIBDIR)/$(HEADER_NAME)"
+	$(INSTALL_DATA) $(HEADER_NAME) "$(INSTALL_LIBDIR)/$(HEADER_NAME)"
 
 ifeq "$(RUNTIMED)" "true"
 install::
@@ -141,14 +141,10 @@ target_camlheader%: tmpheader.exe
 endif
 
 MANGLING = $(filter true,$(SUFFIXING))
-target_$(HEADER_NAME): tmpheader.exe
+$(HEADER_NAME) target_$(HEADER_NAME): tmpheader.exe
 	@{ printf '$(if $(MANGLING),$(ZINC_RUNTIME_ID_HI),\000)'; \
      cat $^; } > $@
 
-$(HEADER_NAME): runtime.info tmpheader.exe
-	@{ cat $^; \
-     printf '$(if $(filter true,$(SUFFIXING)),$(ZINC_RUNTIME_ID))'; } > $@
-
 # The mingw-w64 and MSVC versions of tmpheader.exe are linked with special flags
 # to reduce their size (considerably). In particular, the entry point is
 # overridden, which prevents the linking of crt0.
@@ -197,7 +193,7 @@ stdlib.cmxa: $(OBJS:.cmo=.cmx)
 
 .PHONY: distclean
 distclean: clean
-	rm -f sys.ml runtime.info target_runtime.info
+	rm -f sys.ml
 
 .PHONY: clean
 clean::
diff --git a/stdlib/header.c b/stdlib/header.c
index 95b72d723af199c28f260996d39b7c83f2ac4d9a..d5f5877be918ad3917cb654919d58b8799af7aae 100644
--- a/stdlib/header.c
+++ b/stdlib/header.c
@@ -355,15 +355,6 @@ NORETURN void search_and_exec_runtime(char_os *rntm, uint32_t rntm_bsz,
   /* The first character of rntm is NUL for Search mode */
   if (*rntm != 0) {
     int status;
-    /* boot/ocamlc writes a NUL-terminated string to RNTM. In this case,
-       rntm_bindir_end points to that NUL (which will have been included in the
-       length of RNTM recorded in the bytecode image) and immediately following
-       it is the extra NUL character required by this function.
-       Interpret this as Absolute. For Windows, where the RNTM written by
-       boot/ocamlc will have just been "ocamlrun\0", this maintains the required
-       Search behaviour! This can be removed after a bootstrap. */
-    if (rntm_bindir_end + 1 == rntm_end)
-      rntm_bindir_end++;
     /* For Absolute mode, there is no NUL in RNTM, so rntm_bindir_end points to
        the terminator pointed to be rntm_end. For Absolute_then_search, there is
        a NUL in the middle of the RNTM "string", which rntm_bindir_end points
diff --git a/tools/Makefile b/tools/Makefile
index 518ffe310b6431040b6c0a5e31ba60db6549acfc..5ff2dd99f2a3f15ab466e89f225b1551905a92e5 100644
--- a/tools/Makefile
+++ b/tools/Makefile
@@ -306,14 +306,7 @@ checkstack$(EXE): checkstack.$(O)
 caml_tex := caml-tex$(EXE)
 
 ifeq "$(SUPPORTS_SHARED_LIBRARIES)" "true"
-$(caml_tex): LINKFLAGS += $(ROOT_LINK_FLAGS)
-endif
-ifeq "$(SUFFIXING)-$(UNIX_OR_WIN32)" "true-win32"
-$(caml_tex): LINKFLAGS += -runtime-variant -$(ZINC_RUNTIME_ID)
-else ifeq "$(SUFFIXING)" "true"
-$(caml_tex): LINKFLAGS += \
-  -use-prims $(ROOTDIR)/runtime/primitives \
-  -use-runtime $(call QUOTE_SINGLE,$(BINDIR)/ocamlrun-$(ZINC_RUNTIME_ID))
+$(caml_tex): LINKFLAGS += $(BYTECODE_LAUNCHER_FLAGS)
 endif
 
 # caml-tex uses str.cma and unix.cma and so must be compiled with
