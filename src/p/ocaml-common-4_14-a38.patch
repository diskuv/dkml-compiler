From 977b12d6285935757f0d0372e2df9f053ba36e35 Mon Sep 17 00:00:00 2001
From: David Allsopp <david.allsopp@metastack.com>
Date: Thu, 30 Jan 2025 13:21:29 +0000
Subject: [PATCH] Tidy installation of static builds

- $libdir/stublibs is no longer created for a --disable-shared build
- When $libdir/stublibs is not created, it is also not added to ld.conf

(cherry picked from commit 5ca89cf24dae1b24071d3f5688947d052fbf1172)

diff --git a/Changes b/Changes
index 8da5ff12847b55c81a57f91d3ee1419ea13ad737..333b89535487d37dd26e940e142b2f890ff9ef63 100644
--- a/Changes
+++ b/Changes
@@ -67,7 +67,9 @@ OCaml 4.14 maintenance version
   (David Allsopp and Samuel Hym, review by Antonin Décimo and Gabriel Scherer)
 
 - #14???: New configure option --with-stublibs allows an additional directory
-  to be added to the start of ld.conf.
+  to be added to the start of ld.conf. Additionally, the stublibs subdirectory
+  is no longer created, nor added to ld.conf, when building OCaml with
+  --disable-shared.
   (David Allsopp, review by ???)
 
 ### Bug fixes:
diff --git a/Makefile b/Makefile
index 1c12235e76f62a86327a2343f9e8fa72ad24f5c5..b38edf9c8e254a3281c1958de879c802d8fb5bf9 100644
--- a/Makefile
+++ b/Makefile
@@ -375,7 +375,9 @@ DOC_FILES=\
 install:
 	$(MKDIR) "$(INSTALL_BINDIR)"
 	$(MKDIR) "$(INSTALL_LIBDIR)"
+ifeq "$(SUPPORTS_SHARED_LIBRARIES)" "true"
 	$(MKDIR) "$(INSTALL_STUBLIBDIR)"
+endif
 	$(MKDIR) "$(INSTALL_COMPLIBDIR)"
 	$(MKDIR) "$(INSTALL_DOCDIR)"
 	$(MAKE) -C runtime install
