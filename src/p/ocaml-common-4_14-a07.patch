+- #12751: --with-target-bindir configure option implemented. This option
+  refers to the location of the runtime binaries on the target system for a
+  cross-compiler and is embedded in executables produced by ocamlc. It does
+  not affect the bytecode executables installed as part of the build.
+  (David Allsopp, review by Damien Doligez, Xavier Leroy and Olivier Nicole)
 ### Bug fixes:
 
 - #12070, #12075, #13209: auto-detect whether `ar` support @FILE arguments at
diff --git a/Makefile.build_config.in b/Makefile.build_config.in
index 8f9b5c3863b3a0460fedc30ae548961c848540b0..f0ec9cc705e4c90a18feb1d63f198c9c0e8728f7 100644
--- a/Makefile.build_config.in
+++ b/Makefile.build_config.in
@@ -24,6 +24,10 @@ INSTALL ?= @INSTALL@ -p
 INSTALL_DATA ?= @INSTALL_DATA@
 INSTALL_PROG ?= @INSTALL_PROGRAM@
 
+# Location of ocamlrun on the target system (path embedded in bytecode
+# executables)
+TARGET_BINDIR = @target_bindir@
+
 # Whether to install the native toplevel (ocamlnat)
 INSTALL_OCAMLNAT = @install_ocamlnat@
 
