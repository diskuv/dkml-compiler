index c4edb0e3d441eeb21a81fbfbbd5e1c3fcc8571e7..66bb1a92c994c4abe6b13599214fcd05cde00c3d 100644
--- a/configure.ac
+++ b/configure.ac
@@ -169,6 +169,7 @@ AC_SUBST([compute_deps])
 AC_SUBST([naked_pointers])
 AC_SUBST([naked_pointers_checker])
 AC_SUBST([ar_supports_response_files])
