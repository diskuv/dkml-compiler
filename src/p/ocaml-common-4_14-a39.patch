From fffdca26fe6b1fbd0c9858e0d663b8debc73551d Mon Sep 17 00:00:00 2001
From: David Allsopp <david.allsopp@metastack.com>
Date: Wed, 12 Feb 2025 22:06:29 +0000
Subject: [PATCH] Add Misc.Stdlib.String.to_utf_8_seq

(cherry picked from commit b48ba73a22dbf499133dcb1dbd8464be41f5e8a8)
(cherry picked from commit a507a3af0faf4ef600fa8f328be3c9f4682e3195)

diff --git a/utils/misc.ml b/utils/misc.ml
index 942061720d85e4983b0cfc415d191a543f30efe9..f86c0c917f8e955b749e5708ee1d4df0ace423a9 100644
--- a/utils/misc.ml
+++ b/utils/misc.ml
@@ -225,6 +225,16 @@ module Stdlib = struct
       in
       loop 0
 
+    let rec to_utf_8_seq b i () =
+      if i >= Bytes.length b then
+        Seq.Nil
+      else
+        let next = Bytes.get_utf_8_uchar b i in
+        let u = Uchar.utf_decode_uchar next in
+        Seq.Cons(u, to_utf_8_seq b (i + Uchar.utf_decode_length next))
+
+    let to_utf_8_seq s = to_utf_8_seq (Bytes.unsafe_of_string s) 0
+
     let print ppf t =
       Format.pp_print_string ppf t
   end
diff --git a/utils/misc.mli b/utils/misc.mli
index 7f21ca8391a9f7a2e51b047d28aea8b2d2d07190..794cf1224128bcf93006efc4c0a6612457172522 100644
--- a/utils/misc.mli
+++ b/utils/misc.mli
@@ -171,6 +171,8 @@ module Stdlib : sig
     val print : Format.formatter -> t -> unit
 
     val for_all : (char -> bool) -> t -> bool
+
+    val to_utf_8_seq : t -> Uchar.t Seq.t
   end
 
   external compare : 'a -> 'a -> int = "%compare"
-- 
