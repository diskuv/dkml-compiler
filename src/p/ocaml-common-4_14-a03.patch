diff --git a/configure.ac b/configure.ac
index 66bb1a92c994c4abe6b13599214fcd05cde00c3d..bd96ad1a7d7c93fc08e10bf8ac2ef3b7dca19d4e 100644
--- a/configure.ac
+++ b/configure.ac
@@ -95,8 +95,10 @@ AC_SUBST([arch64])
 AC_SUBST([model])
 AC_SUBST([system])
 AC_SUBST([systhread_support])
+AC_SUBST([ocamlsrcdir])
 AC_SUBST([unix_or_win32])
 AC_SUBST([unixlib])
+AC_SUBST([ln])
 AC_SUBST([outputexe])
 AC_SUBST([outputobj])
 AC_SUBST([syslib])
@@ -179,6 +181,7 @@ AC_CONFIG_FILES([stdlib/sys.ml])
 AC_CONFIG_FILES([manual/src/version.tex])
 AC_CONFIG_FILES([manual/src/html_processing/src/common.ml])
 AC_CONFIG_FILES([tools/eventlog_metadata])
+AC_CONFIG_FILES([ocamltest/ocamltest_config.mlp])
