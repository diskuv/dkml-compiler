   [*-*-mingw32|*-pc-windows],
     [unix_or_win32="win32"
+    ln='cp -pf'
+    ocamlsrcdir="$(LC_ALL=C.UTF-8 cygpath -w -- "$ocamlsrcdir")"
     unixlib="win32unix"
     ],
   [unix_or_win32="unix"
+  ln='ln -sf'
   unixlib="unix"])
+
 AS_CASE([$host],
   [*-*-cygwin*|*-*-mingw32|*-pc-windows],
     [exeext=".exe"],
