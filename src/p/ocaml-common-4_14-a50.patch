From 564e7d9e382db4edb9dba901eae87e94d7e58cb7 Mon Sep 17 00:00:00 2001
From: David Allsopp <david.allsopp@metastack.com>
Date: Sat, 10 Apr 2021 15:13:19 +0100
Subject: [PATCH] Allow libdir to be found relative to bindir

When configured with --with-relative-libdir, the runtime uses the
directory of the executable to determine the location of the Standard
Library. Thus, ocamlrun and the compilers look for ../lib/ocaml by
default.

This is implemented by changing caml_standard_library_default to be a
relative path, and then computing the actual value at startup (for
bytecode) and when queried (for native).

Executables (and objects) produced by the compiler always have an
absolute value of caml_standard_library_default. ocamlc.opt and
ocamlopt.opt are built using -set-runtime-default to force
caml_standard_library_default to be a relative value.

(cherry picked from commit 205bab8a0d62ddb6ff357de719e5e57406de8745)

diff --git a/Changes b/Changes
index 3bb2f2793a80ffed9c06d6cce537cc06e31001f5..54bbcc2b128f01a2ad2b11cde52d0cf729c53c1b 100644
--- a/Changes
+++ b/Changes
@@ -26,8 +26,12 @@ OCaml 4.14 maintenance version
   both Windows and Unix.
   (David Allsopp, review by ???)
 
-- #14???: Executables linked with `ocamlc -custom` now always attempt to load
-  bytecode from the executable itself, rather than first trying `argv[0]`.
+- #14???: Added --with-relative-bindir which allows the runtime and the
+  compilers to locate the Standard Library relative to where the binaries
+  themselves are installed, removing the absolute path previously embedded in
+  caml_standard_library_default. Executables linked with `ocamlc -custom` now
+  always attempt to load bytecode from the executable itself, rather than first
+  trying `argv[0]`.
   (David Allsopp, review by ???)
 
 ### Code generation and optimizations:
diff --git a/Makefile b/Makefile
index b38edf9c8e254a3281c1958de879c802d8fb5bf9..3623cbd6761618ef3f15fd273aedf43f3cc778ba 100644
--- a/Makefile
+++ b/Makefile
@@ -44,7 +44,7 @@ COMPFLAGS=-strict-sequence -principal -absname \
           -w +a-4-9-40-41-42-44-45-48-66-70 \
           -warn-error +a \
           -bin-annot -safe-string -strict-formats $(INCLUDES)
-LINKFLAGS=
+LINKFLAGS=$(OC_COMMON_LINKFLAGS)
 
 ifeq "$(strip $(NATDYNLINKOPTS))" ""
 OCAML_NATDYNLINKOPTS=
@@ -353,7 +353,8 @@ endif
 flexlink.opt$(EXE):
 	$(MAKE) -C $(FLEXDLL_SOURCES) $(FLEXLINK_BUILD_ENV) \
     OCAML_FLEXLINK='$(value OCAMLRUN) $$(ROOTDIR)/boot/flexlink.byte$(EXE)' \
-	  OCAMLOPT="$(FLEXLINK_OCAMLOPT) -nostdlib -I ../stdlib" flexlink.exe
+	  OCAMLOPT="$(FLEXLINK_OCAMLOPT) -nostdlib -I ../stdlib \
+$(SET_RELATIVE_STDLIB)" flexlink.exe
 	mv $(FLEXDLL_SOURCES)/flexlink.exe $@
 
 partialclean::
@@ -929,6 +930,7 @@ ocamldoc.opt: ocamlc.opt ocamlyacc ocamllex
 ocamltest: ocamlc ocamlyacc ocamllex otherlibraries
 	$(MAKE) -C ocamltest all
 
+
 ocamltest.opt: ocamlc.opt ocamlyacc ocamllex
 	$(MAKE) -C ocamltest allopt
 
diff --git a/Makefile.build_config.in b/Makefile.build_config.in
index e654375de7da6f2abf5680ab6336974a48d2c3ae..176110b0451fe4c4776c9e74776b7071c69252c2 100644
--- a/Makefile.build_config.in
+++ b/Makefile.build_config.in
@@ -54,6 +54,7 @@ DOCDIR=@docdir@
 
 ### Where to look for the standard library on target
 TARGET_LIBDIR=@TARGET_LIBDIR@
+TARGET_LIBDIR_IS_RELATIVE=@target_libdir_is_relative@
 OCAML_BINDIR = @ocaml_bindir@
 
 # Platform-dependent command to create symbolic links
diff --git a/Makefile.common b/Makefile.common
index 1f9a8454dfb471275a40e01c32bf78b0256daed6..80743d1e69b0d46f43102a48f0b876186db5acbf 100644
--- a/Makefile.common
+++ b/Makefile.common
@@ -28,6 +28,15 @@ EMPTY :=
 # $(SPACE) contains a single space
 SPACE := $(EMPTY) $(EMPTY)
 
+ifeq "$(UNIX_OR_WIN32)" "win32"
+DIR_SEP := \$ # There must a space following the $
+CONVERT_PATH = $(subst /,$(DIR_SEP),$(strip $(1)))
+else
+DIR_SEP = /
+CONVERT_PATH = $(strip $(1))
+endif
+
+QUOTE_SINGLE = '$(subst ','\'',$(1))'
 DESTDIR ?=
 INSTALL_BINDIR := $(DESTDIR)$(BINDIR)
 INSTALL_LIBDIR := $(DESTDIR)$(LIBDIR)
@@ -110,9 +119,14 @@ SUBST=-e 's!%%$1%%!$(call SED_ESCAPE,$($1))!'
 # in config.mlp.  Thus, backslashes and double quotes must be escaped.
 SUBST_STRING=-e 's!%%$1%%!$(call SED_ESCAPE,$(call OCAML_ESCAPE,$($1)))!'
 
-# Allow Makefile.cross to add flags to OC_COMMON_LINKFLAGS
-OC_CROSS_LINKFLAGS ?=
-OC_COMMON_LINKFLAGS += $(OC_CROSS_LINKFLAGS)
+# Allow Makefile.cross to override the Standard Library default for the compiler
+# itself.
+HOST_LIBDIR ?= $(TARGET_LIBDIR)
+
+OC_COMMON_LINKFLAGS ?=
+OC_COMMON_LINKFLAGS += \
+  -set-runtime-default \
+    $(call QUOTE_SINGLE,standard_library_default=$(HOST_LIBDIR))
 
 # The rule to compile C files
 
