diff --git a/configure.ac b/configure.ac
index 67f42105dc23727c1cb7ea6c21b0636a24f2eb0b..e8aa3b50e150889f5f5e1598d7123f57dfe8d4b1 100644
--- a/configure.ac
+++ b/configure.ac
@@ -576,11 +576,13 @@ AS_CASE([$host],
   [*-*-mingw32|*-pc-windows],
     [unix_or_win32="win32"
     OCAML_CHECK_LN_ON_WINDOWS
+    default_separator='\'
     ocamlsrcdir="$(LC_ALL=C.UTF-8 cygpath -w -- "$ocamlsrcdir")"
     unixlib="win32unix"
     ],
   [unix_or_win32="unix"
   ln='ln -sf'
+  default_separator='/'
   unixlib="unix"])
 
 AS_CASE([$host],
@@ -2151,10 +2153,11 @@ AC_CONFIG_COMMANDS([runtime/ld.conf],
   [rm -f runtime/ld.conf
   test x"$ocaml_additional_stublibs_dir" = 'x' || \
     echo "$ocaml_additional_stublibs_dir" > runtime/ld.conf
-  echo "$ocaml_libdir/stublibs" >> runtime/ld.conf
-  echo "$ocaml_libdir" >> runtime/ld.conf],
+  echo ".${default_separator}stublibs" >> runtime/ld.conf
+  echo "." >> runtime/ld.conf],
   [ocaml_additional_stublibs_dir=\
 '$(echo "$ocaml_additional_stublibs_dir" | sed -e "s/'/'\"'\"'/g")'
-  ocaml_libdir='$(echo "$ocaml_libdir" | sed -e "s/'/'\"'\"'/g")'])
+  ocaml_libdir='$(echo "$ocaml_libdir" | sed -e "s/'/'\"'\"'/g")'
+  default_separator='$default_separator'])
 
 AC_OUTPUT
diff --git a/ocaml-variants.opam b/ocaml-variants.opam
index da0d7469bbd78a68016c142c26969b539c89a119..0ed93f0bc13e8655eef4828d54d9f500f5e27a5c 100644
--- a/ocaml-variants.opam
+++ b/ocaml-variants.opam
@@ -65,7 +65,8 @@ build: [
     "--host=i686-w64-mingw32"   {os-distribution = "cygwin" & system-mingw:installed & arch-x86_32:installed}
     "--prefix=%{prefix}%"
     "--docdir=%{doc}%/ocaml"
-    "--with-stublibs=%{stublibs}%"
+    "--with-stublibs=../stublibs" {os != "win32"}
+    "--with-stublibs=..\\stublibs" {os = "win32"}
     "--with-flexdll=%{flexdll:share}%" {os = "win32" & flexdll:installed}
     "-C"
     "--with-afl" {ocaml-option-afl:installed}
