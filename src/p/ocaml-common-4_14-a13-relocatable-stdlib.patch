+  } else {
+    root_dir = caml_copy_string_of_os(root);
+    root_dir = caml_alloc_some(root_dir);
+  }
+  result = caml_alloc_small(2, 0);
+  Field(result, 0) = eff;
+  Field(result, 1) = root_dir;
+
+  CAMLreturn(result);
+}
